{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "flowscope",
  "compatibility_date": "2026-04-26",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "flowscope.modevium.com",
      "custom_domain": true
    }
  ]
}
